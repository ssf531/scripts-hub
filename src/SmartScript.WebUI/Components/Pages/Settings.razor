@page "/settings"
@rendermode InteractiveServer

<PageTitle>Settings - SmartScript Hub</PageTitle>

<h3 class="mb-4"><i class="bi bi-gear-fill me-2"></i>Global Settings</h3>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">Ollama Configuration</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Ollama API URL</label>
                    <input type="text" class="form-control" value="@_ollamaUrl" disabled />
                    <div class="form-text">Configured via environment variable OLLAMA_BASE_URL or appsettings.json.</div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">Plugin Directory</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Path</label>
                    <input type="text" class="form-control" value="@_pluginDir" disabled />
                    <div class="form-text">Place compiled .dll plugin files in this directory. They will be auto-discovered on startup.</div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">Gmail OAuth</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Upload your Google OAuth <code>credentials.json</code> to <code>/app/config/</code> to enable Gmail integration. The authorization flow will start automatically when the Email Cleaner script first runs.</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IConfiguration Configuration { get; set; } = default!;

    private string _ollamaUrl = string.Empty;
    private string _pluginDir = string.Empty;

    protected override void OnInitialized()
    {
        _ollamaUrl = Configuration["OLLAMA_BASE_URL"]
            ?? Configuration["Ollama:BaseUrl"]
            ?? "http://localhost:11434";
        _pluginDir = Configuration["PluginDirectory"] ?? "/app/plugins";
    }
}
